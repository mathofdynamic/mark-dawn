<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window / panel backgrounds -->
    <SolidColorBrush x:Key="WindowBgBrush"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ToolbarBgBrush"     Color="#252526"/>
    <SolidColorBrush x:Key="MenuBgBrush"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceBrush"       Color="#2D2D2D"/>
    <SolidColorBrush x:Key="EditorBgBrush"      Color="#1E1E1E"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"        Color="#3C3C3C"/>
    <SolidColorBrush x:Key="BorderHoverBrush"   Color="#555555"/>
    <SolidColorBrush x:Key="SplitterBrush"      Color="#3C3C3C"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#858585"/>
    <SolidColorBrush x:Key="TextModifiedBrush"  Color="#FFD700"/>
    <SolidColorBrush x:Key="EditorFgBrush"      Color="#D4D4D4"/>
    <SolidColorBrush x:Key="LineNumberFgBrush"  Color="#858585"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="BtnBgBrush"         Color="Transparent"/>
    <SolidColorBrush x:Key="BtnHoverBgBrush"    Color="#3C3C3C"/>
    <SolidColorBrush x:Key="BtnPressedBgBrush"  Color="#007ACC"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#007ACC"/>
    <SolidColorBrush x:Key="StatusBarBgBrush"   Color="#007ACC"/>
    <SolidColorBrush x:Key="StatusBarFgBrush"   Color="#FFFFFF"/>


</ResourceDictionary>
