<Window x:Class="MarkDawn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="mark-dawn"
        Width="1300" Height="840"
        MinWidth="680" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>

        <!--
            TBBtn — flat toolbar button.
            Background/BorderThickness are HARDCODED in the template (no TemplateBinding
            for layout-affecting properties) so WPF's GetFlattenedEntry never recurses.
            DynamicResource is only used for Foreground (Style setter, not template) and
            for non-layout Background values in ControlTemplate.Triggers.
        -->
        <Style x:Key="TBBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle"  Value="True"/>
            <Setter Property="Foreground"             Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding"                Value="8,0"/>
            <Setter Property="Margin"                 Value="1,2"/>
            <Setter Property="FontFamily"             Value="Segoe UI"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Height"                 Value="26"/>
            <Setter Property="FocusVisualStyle"       Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource BtnHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource BtnPressedBgBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar separator -->
        <Style x:Key="TBSep" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Width="1" Margin="5,4"
                                   Fill="{DynamicResource BorderBrush}"
                                   VerticalAlignment="Stretch"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════ MENU ══════════════════ -->
        <Menu Grid.Row="0"
              Background="{DynamicResource MenuBgBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              FontFamily="Segoe UI" FontSize="13"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_New"                     Click="New_Click"                InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open…"                   Click="Open_Click"               InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"                    Click="Save_Click"               InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"                Click="SaveAs_Click"             InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="Register .md Association" Click="RegisterAssociation_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"                    Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"            Click="Undo_Click"  InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"            Click="Redo_Click"  InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Find…"           Click="Find_Click"  InputGestureText="Ctrl+F"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Preview"  Click="TogglePreview_Click" InputGestureText="F5"/>
                <MenuItem Header="Toggle _Editor"   Click="ToggleEditor_Click"  InputGestureText="F6"/>
                <MenuItem Header="_Focus Mode"      Click="FocusMode_Click"     InputGestureText="F11"/>
                <Separator/>
                <MenuItem Header="_Word Wrap"       Click="WordWrap_Click"      InputGestureText="Alt+Z"
                          x:Name="MenuWordWrap"     IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Show Line _Numbers" Click="LineNumbers_Click"
                          x:Name="MenuLineNumbers"    IsCheckable="True" IsChecked="True"/>
                <Separator/>
                <MenuItem Header="_Dark Theme"      Click="ForceDark_Click"/>
                <MenuItem Header="_Light Theme"     Click="ForceLight_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Open _Log Folder" Click="OpenLogs_Click"/>
                <Separator/>
                <MenuItem Header="_About mark-dawn"  Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ══════════════════ TOOLBAR ══════════════════ -->
        <Border Grid.Row="1"
                Height="38"
                Background="{DynamicResource ToolbarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalAlignment="Center"
                          Focusable="False">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="6,0">

                    <!-- Text formatting -->
                    <Button FontWeight="Bold"  Click="Bold_Click"   ToolTip="Bold (Ctrl+B)"      Style="{StaticResource TBBtn}">B</Button>
                    <Button FontStyle="Italic" Click="Italic_Click" ToolTip="Italic (Ctrl+I)"    Style="{StaticResource TBBtn}">I</Button>
                    <Button                    Click="Strike_Click" ToolTip="Strikethrough"       Style="{StaticResource TBBtn}">
                        <TextBlock TextDecorations="Strikethrough" Text="S"/>
                    </Button>

                    <Separator Style="{StaticResource TBSep}"/>

                    <!-- Headings -->
                    <Button Click="H1_Click" ToolTip="Heading 1 (##)" Style="{StaticResource TBBtn}" FontWeight="Bold"   FontSize="11">H1</Button>
                    <Button Click="H2_Click" ToolTip="Heading 2 (##)" Style="{StaticResource TBBtn}" FontWeight="SemiBold" FontSize="11">H2</Button>
                    <Button Click="H3_Click" ToolTip="Heading 3 (###)" Style="{StaticResource TBBtn}" FontSize="11">H3</Button>

                    <Separator Style="{StaticResource TBSep}"/>

                    <!-- Insert -->
                    <Button Click="Link_Click"  ToolTip="Insert link"    Style="{StaticResource TBBtn}">🔗</Button>
                    <Button Click="Image_Click" ToolTip="Insert image"   Style="{StaticResource TBBtn}">🖼</Button>

                    <Separator Style="{StaticResource TBSep}"/>

                    <!-- Code -->
                    <Button Click="Code_Click"      ToolTip="Inline code (`code`)"  Style="{StaticResource TBBtn}" FontFamily="Consolas" FontSize="12">`code`</Button>
                    <Button Click="CodeBlock_Click" ToolTip="Code block (``` ... ```)" Style="{StaticResource TBBtn}" FontFamily="Consolas" FontSize="11">```</Button>

                    <Separator Style="{StaticResource TBSep}"/>

                    <!-- Lists -->
                    <Button Click="BulletList_Click" ToolTip="Bullet list"   Style="{StaticResource TBBtn}">• List</Button>
                    <Button Click="NumberList_Click" ToolTip="Ordered list"  Style="{StaticResource TBBtn}">1. List</Button>
                    <Button Click="Quote_Click"      ToolTip="Blockquote"    Style="{StaticResource TBBtn}">❝ Quote</Button>

                    <Separator Style="{StaticResource TBSep}"/>

                    <!-- Block elements -->
                    <Button Click="HR_Click"    ToolTip="Horizontal rule"  Style="{StaticResource TBBtn}">─ Rule</Button>
                    <Button Click="Table_Click" ToolTip="Insert 3×2 table" Style="{StaticResource TBBtn}">⊞ Table</Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ══════════════════ CONTENT ══════════════════ -->
        <!-- Editor and Preview live in separate child Grids so the
             WebView2 native HWND cannot paint over the editor (airspace). -->
        <Grid Grid.Row="2" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" x:Name="ColEditor"/>
                <ColumnDefinition Width="5" x:Name="ColSplitter"/>
                <ColumnDefinition Width="*" x:Name="ColPreview"/>
            </Grid.ColumnDefinitions>

            <ae:TextEditor
                x:Name="Editor"
                Grid.Column="0"
                FontFamily="Consolas"
                FontSize="14"
                ShowLineNumbers="True"
                WordWrap="True"
                Background="{DynamicResource EditorBgBrush}"
                Foreground="{DynamicResource EditorFgBrush}"
                LineNumbersForeground="{DynamicResource LineNumberFgBrush}"
                Padding="8,4"/>

            <GridSplitter
                Grid.Column="1"
                Width="5"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource SplitterBrush}"
                ResizeBehavior="PreviousAndNext"/>

            <wv2:WebView2 x:Name="Preview" Grid.Column="2"/>

            <!-- Error overlay: shown when WebView2 fails to initialise. -->
            <Border x:Name="PreviewErrorBorder"
                    Grid.Column="2"
                    Visibility="Collapsed"
                    Background="{DynamicResource EditorBgBrush}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="32">
                    <TextBlock Text="Preview unavailable"
                               FontSize="15" FontFamily="Segoe UI" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PreviewErrorMsg"
                               Text="WebView2 runtime could not be initialised."
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="320"
                               Margin="0,8,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════ STATUS BAR ══════════════════ -->
        <Border Grid.Row="3"
                Height="24"
                Background="{DynamicResource StatusBarBgBrush}">
            <Grid Margin="10,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: file path + modified badge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtFilePath"
                               Text="Untitled"
                               Foreground="{DynamicResource StatusBarFgBrush}"
                               FontSize="11" FontFamily="Segoe UI"/>
                    <Border x:Name="ModifiedBadge"
                            Margin="8,0,0,0" Padding="6,1"
                            Background="#00000025"
                            CornerRadius="3"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtModified"
                                   Text="modified"
                                   Foreground="{DynamicResource StatusBarFgBrush}"
                                   FontSize="10" FontFamily="Segoe UI" Opacity="0.9"/>
                    </Border>
                </StackPanel>

                <!-- Right: word count | line:col -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtWordCount"
                               Foreground="{DynamicResource StatusBarFgBrush}"
                               FontSize="11" FontFamily="Segoe UI" Opacity="0.85"
                               Text="0 words"/>
                    <TextBlock Foreground="{DynamicResource StatusBarFgBrush}"
                               FontSize="11" Opacity="0.45" Text="   |   "/>
                    <TextBlock x:Name="TxtPosition"
                               Foreground="{DynamicResource StatusBarFgBrush}"
                               FontSize="11" FontFamily="Segoe UI" Opacity="0.85"
                               Text="Ln 1  Col 1"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
